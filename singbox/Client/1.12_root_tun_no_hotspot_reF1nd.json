{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "providers": [
    {
      "type": "remote",
      "tag": "provider1",
      "url": "",
      "exclude": "",
      "user_agent": "sing-box",
      "download_detour": "direct"
    },
    {
      "type": "remote",
      "tag": "provider2",
      "url": "",
      "exclude": "",
      "user_agent": "sing-box",
      "download_detour": "direct"
    }
  ],
  "dns": {
    "servers": [
      {
        "type": "hosts",
        "tag": "host",
        "predefined": {
          "dot.pub": [
            "120.53.53.53",
            "1.12.12.21"
          ],
          "doh.pub": [
            "120.53.53.53",
            "1.12.12.21"
          ],
          "dns.alidns.com": [
            "223.5.5.5",
            "223.6.6.6"
          ]
        }
      },
      {
        "type": "group",
        "tag": "local",
        "servers": [
          "tls",
          "quic"
        ]
      },
      {
        "type": "tls",
        "tag": "tls",
        "domain_resolver": "host",
        "server": "dot.pub"
      },
      {
        "type": "quic",
        "tag": "quic",
        "domain_resolver": "host",
        "server": "dns.alidns.com"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "local"
      },
      {
        "clash_mode": "Global",
        "server": "fakeip"
      },
      {
        "query_type": "HTTPS",
        "action": "reject"
      },
      {
        "rule_set": [
          "geosite-connectivity-check",
          "geosite-private"
        ],
        "invert": true,
        "server": "fakeip",
        "rewrite_ttl": 1
      },
      {
        "rule_set": "geosite-cn",
        "server": "local"
      }
    ],
    "final": "local"
  },
  "inbounds": [
    {
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 2080
    },
    {
      "type": "tun",
      "tag": "tun",
      "interface_name": "sing-box",
      "address": [
        "172.18.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "stack": "system",
      "auto_route": true,
      "strict_route": true,
      "auto_redirect": true
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Global",
      "use_all_providers": true,
      "interrupt_exist_connections": true,
      "exclude": "_shadowtls"
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": [
          "quic"
        ],
        "action": "reject"
      },
      {
        "sniffer": [
          "http",
          "tls",
          "dns"
        ],
        "action": "sniff",
        "timeout": "500ms"
      },
      {
        "source_ip_cidr": [
          "172.18.0.1/30",
          "fdfe:dcba:9876::1/126",
          "127.0.0.0/8"
        ],
        "invert": true,
        "action": "bypass",
        "outbound": "direct"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "port": 53
          },
          {
            "source_ip_cidr": [
              "172.18.0.1/30",
              "fdfe:dcba:9876::1/126",
              "127.0.0.0/8"
            ]
          }
        ],
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "Global"
      },
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "rule_set": "ad",
        "action": "reject"
      },
      {
        "rule_set": "google",
        "outbound": "Global"
      },
      {
        "rule_set": [
          "geosite-cn"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-cn"
        ],
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "action": "resolve",
        "match_only": true
      },
      {
        "rule_set": [
          "geoip-cn"
        ],
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "ad",
        "url": "https://raw.githubusercontent.com/qiuxiuya/AdRules/main/adrules-singbox.srs",
        "download_detour": "Global"
      },
      {
        "type": "remote",
        "tag": "geosite-cn",
        "url": "https://raw.githubusercontent.com/Mikuu3930/meta-rules-dat/refs/heads/sing/geo/geosite/cn.srs",
        "download_detour": "Global"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "url": "https://raw.githubusercontent.com/Mikuu3930/meta-rules-dat/refs/heads/sing/geo/geoip/cn.srs",
        "download_detour": "Global"
      },
      {
        "type": "remote",
        "tag": "google",
        "url": "https://raw.githubusercontent.com/Mikuu3930/meta-rules-dat/refs/heads/sing/geo/geosite/google.srs",
        "download_detour": "Global"
      },
      {
        "type": "remote",
        "tag": "geosite-connectivity-check",
        "url": "https://raw.githubusercontent.com/Mikuu3930/meta-rules-dat/refs/heads/sing/geo/geosite/connectivity-check.srs",
        "download_detour": "Global"
      },
      {
        "type": "remote",
        "tag": "geosite-private",
        "url": "https://raw.githubusercontent.com/Mikuu3930/meta-rules-dat/refs/heads/sing/geo/geosite/private.srs",
        "download_detour": "Global"
      }
    ],
    "final": "Global",
    "auto_detect_interface": true,
    "default_domain_resolver": "local"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "dashboard",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_download_detour": "Global"
    }
  }
}